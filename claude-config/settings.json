{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(tree *)",
      "Bash(diff *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(date)",
      "Bash(date *)",
      "Bash(echo *)",
      "Bash(true)",
      "Bash(test *)",
      "Bash(node --version)",
      "Bash(node -v)",
      "Bash(npm --version)",
      "Bash(npm -v)",
      "Bash(npm list*)",
      "Bash(npm ls*)",
      "Bash(npm view*)",
      "Bash(npm outdated*)",
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(npx --version)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git blame *)",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.env)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/*.env)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/*.env)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/*credentials*)",
      "Read(**/*secret*)",
      "Read(**/.npmrc)",
      "Read(**/.netrc)",
      "Read(**/.pypirc)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Bash(cat *.env*)",
      "Bash(cat *.pem)",
      "Bash(cat *.key)",
      "Bash(cat *credentials*)",
      "Bash(cat *secret*)",
      "Bash(grep * .env*)",
      "Bash(head *.env*)",
      "Bash(tail *.env*)",
      "Bash(less *.env*)",
      "Bash(more *.env*)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf .)",
      "Bash(rm -rf ..)",
      "Bash(chmod -R 777 *)",
      "Bash(chmod 777 *)",
      "Bash(dd if=*)",
      "Bash(mkfs*)",
      "Bash(shred *)",
      "Bash(>/dev/*)",
      "Bash(sed *)",
      "Bash(gsed *)",
      "Bash(npm publish*)",
      "Bash(yarn publish*)",
      "Bash(pnpm publish*)",
      "Bash(npm install -g *)",
      "Bash(npm i -g *)",
      "Bash(yarn global add *)",
      "Bash(pnpm add -g *)",
      "Bash(sudo *)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(wget * | bash*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "opus",
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "theme": "light",
  "remoteControlAtStartup": false,
  "skipAutoPermissionPrompt": true
}
